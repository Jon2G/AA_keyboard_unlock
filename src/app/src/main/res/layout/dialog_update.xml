<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/text_update_version"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        tools:text="v2.0.2" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:maxHeight="240dp">

        <TextView
            android:id="@+id/text_update_changelog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            tools:text="Bug fixes and improvements." />
    </ScrollView>

    <TextView
        android:id="@+id/text_update_lsposed_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:text="@string/update_lsposed_hint"
        android:textAppearance="?attr/textAppearanceBodySmall" />

    <ProgressBar
        android:id="@+id/progress_update_download"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:max="100"
        android:visibility="gone"
        tools:progress="40"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/text_update_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:visibility="gone"
        tools:text="Downloading…"
        tools:visibility="visible" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_update_later"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/update_later" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_update_github"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/update_open_github"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_update_install"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/update_install" />
    </LinearLayout>

</LinearLayout>
